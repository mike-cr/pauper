      <image>https://raw.githubusercontent.com/mike-cr/pauper/main/data/screenshots/downloaded.png</image>
      <caption>Browse downloaded voices and choose the synthesis voice</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/mike-cr/pauper/main/data/screenshots/settings.png</image>
