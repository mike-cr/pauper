<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.mike_cr.Pauper</id>
  <name>Pauper</name>
  <summary>Manage the Pauper speech service</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <developer id="io.github.mike_cr">
    <name>Mike Cribbens</name>
  </developer>
  <description>
    <p>
      Pauper keeps a selected Piper text-to-speech voice loaded in memory and exposes
      it to Speech Dispatcher through a lightweight local service.
    </p>
    <p>
      The manager is designed for phone-sized Linux devices and can download voices,
      preview samples, choose speakers, and control daemon memory behavior.
    </p>
  </description>
  <url type="homepage">https://github.com/mike-cr/pauper</url>
  <url type="bugtracker">https://github.com/mike-cr/pauper/issues</url>
  <url type="vcs-browser">https://github.com/mike-cr/pauper</url>
  <launchable type="desktop-id">io.github.mike_cr.Pauper.desktop</launchable>
  <content_rating type="oars-1.1" />
  <branding>
    <color type="primary" scheme_preference="light">#2f7d68</color>
    <color type="primary" scheme_preference="dark">#2f7d68</color>
  </branding>
  <screenshots>
