#!/usr/bin/make -f

export PYBUILD_NAME=pauper
DEB_VERSION := $(shell dpkg-parsechangelog -SVersion 2>/dev/null || printf '0+unknown')

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	printf '%s\n' '"""Build-generated package version."""' '' '__version__ = "$(DEB_VERSION)"' > pauper/_version.py
	dh_auto_build

override_dh_auto_clean:
	rm -f pauper/_version.py
	dh_auto_clean
